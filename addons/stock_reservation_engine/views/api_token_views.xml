<odoo>
    <record id="view_reservation_api_token_tree" model="ir.ui.view">
        <field name="name">reservation.api.token.tree</field>
        <field name="model">reservation.api.token</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="user_id"/>
                <field name="token"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_reservation_api_token_form" model="ir.ui.view">
        <field name="name">reservation.api.token.form</field>
        <field name="model">reservation.api.token</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="user_id"/>
                        <field name="token" password="True"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_reservation_api_token" model="ir.actions.act_window">
        <field name="name">Reservation API Tokens</field>
        <field name="res_model">reservation.api.token</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
