<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Search: filters + group-by for graph/pivot -->
    <record id="view_stock_reservation_line_dashboard_search" model="ir.ui.view">
        <field name="name">stock.reservation.line.search.dashboard</field>
        <field name="model">stock.reservation.line</field>
        <field name="arch" type="xml">
            <search string="Reservation Lines">
                <field name="product_id"/>
                <field name="state"/>
                <field name="batch_id"/>
                <separator/>
                <filter string="Allocated" name="flt_allocated" domain="[('state', '=', 'allocated')]"/>
                <filter string="Partial" name="flt_partial" domain="[('state', '=', 'partial')]"/>
                <filter string="Not Available" name="flt_not_available" domain="[('state', '=', 'not_available')]"/>
                <group expand="0" string="Group By">
                    <filter string="Product" name="groupby_product" context="{'group_by': 'product_id'}"/>
                    <filter string="State" name="groupby_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Bar chart: state on category axis; optional stack by product; measures for volume -->
    <record id="view_stock_reservation_line_graph_dashboard" model="ir.ui.view">
        <field name="name">stock.reservation.line.graph.dashboard</field>
        <field name="model">stock.reservation.line</field>
        <field name="arch" type="xml">
            <graph string="Reservation Lines" type="bar" stacked="True" sample="1">
                <field name="state"/>
                <field name="product_id"/>
                <field name="requested_qty" string="Requested Qty" type="measure"/>
                <field name="allocated_qty" string="Allocated Qty" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Pivot: product × state × quantities -->
    <record id="view_stock_reservation_line_pivot_dashboard" model="ir.ui.view">
        <field name="name">stock.reservation.line.pivot.dashboard</field>
        <field name="model">stock.reservation.line</field>
        <field name="arch" type="xml">
            <pivot string="Reservation Lines" sample="1">
                <field name="product_id" type="row"/>
                <field name="state" type="col"/>
                <field name="requested_qty" string="Requested Qty" type="measure"/>
                <field name="allocated_qty" string="Allocated Qty" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_reservation_dashboard" model="ir.actions.act_window">
        <field name="name">Reservation Dashboard</field>
        <field name="res_model">stock.reservation.line</field>
        <field name="view_mode">graph,pivot</field>
        <field name="search_view_id" ref="view_stock_reservation_line_dashboard_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No reservation lines to analyze.
            </p>
            <p>
                Confirm and allocate reservation batches to populate this dashboard.
            </p>
        </field>
    </record>

</odoo>
