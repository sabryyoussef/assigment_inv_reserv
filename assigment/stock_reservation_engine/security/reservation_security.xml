<odoo>
    <record id="group_stock_reservation_user" model="res.groups">
        <field name="name">Stock Reservation User</field>
        <field name="category_id" ref="base.module_category_inventory"/>
    </record>

    <record id="group_stock_reservation_manager" model="res.groups">
        <field name="name">Stock Reservation Manager</field>
        <field name="category_id" ref="base.module_category_inventory"/>
        <field name="implied_ids" eval="[(4, ref('group_stock_reservation_user'))]"/>
    </record>

    <record id="stock_reservation_batch_user_rule" model="ir.rule">
        <field name="name">Reservation batches: own only</field>
        <field name="model_id" ref="model_stock_reservation_batch"/>
        <field name="groups" eval="[(4, ref('group_stock_reservation_user'))]"/>
        <field name="domain_force">[('request_user_id', '=', user.id)]</field>
    </record>

    <record id="stock_reservation_line_user_rule" model="ir.rule">
        <field name="name">Reservation lines: own only</field>
        <field name="model_id" ref="model_stock_reservation_line"/>
        <field name="groups" eval="[(4, ref('group_stock_reservation_user'))]"/>
        <field name="domain_force">[('batch_id.request_user_id', '=', user.id)]</field>
    </record>

    <record id="reservation_api_token_manager_rule" model="ir.rule">
        <field name="name">Reservation API tokens: manager only</field>
        <field name="model_id" ref="model_reservation_api_token"/>
        <field name="groups" eval="[(4, ref('group_stock_reservation_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
</odoo>
